# ─────────────────────────────────────────────────────────────────────────────
# KOH HOUSE — Environment Variables
# Copy this file to .env and fill in your values before running locally.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── GitHub Integration ────────────────────────────────────────────────────────
# Personal Access Token used by Netlify Functions to read/write data files.
# Required scopes: repo (full) — see SETUP.md §5 for instructions.
GITHUB_TOKEN=

# The GitHub account or organisation that owns the repository.
GITHUB_OWNER=

# The repository name (e.g. koh-house).
GITHUB_REPO=

# ── Admin Authentication ──────────────────────────────────────────────────────
# The email address used to log in to the admin panel.
ADMIN_EMAIL=admin@kohhouse.com

# SHA-256 hash of the admin password. Generate via:
#   node -e "const c=require('crypto');console.log(c.createHash('sha256').update('yourpassword').digest('hex'))"
# See SETUP.md §4 for full instructions.
ADMIN_PASSWORD_HASH=

# A long random string used to sign admin session tokens. Generate via:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# ── Stripe Payments ───────────────────────────────────────────────────────────
# Your Stripe secret key. Use sk_test_... for testing, sk_live_... for production.
# Find in Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_test_

# Your Stripe publishable key. Use pk_test_... for testing, pk_live_... for production.
STRIPE_PUBLISHABLE_KEY=pk_test_

# Webhook signing secret from Stripe Dashboard → Developers → Webhooks.
# Used to verify that webhook events genuinely originate from Stripe.
STRIPE_WEBHOOK_SECRET=whsec_

# ── Site Configuration ────────────────────────────────────────────────────────
# The full public URL of the deployed site (no trailing slash).
# Used to build return URLs for Stripe Checkout.
# Example: https://kohhouse.netlify.app  or  https://www.kohhouse.com
SITE_URL=https://kohhouse.netlify.app
